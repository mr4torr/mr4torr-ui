{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "composite": true, // Obrigatório para referências
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "strict": true,
        "paths": {
            "@mr4torr/ui/*": ["./src/*"]
        }
    },
    "include": ["."],
    "exclude": ["node_modules", "dist", ".storybook", "docs"]
}
