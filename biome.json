{
    "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "a11y": {
                "useSemanticElements": "off",
                "noLabelWithoutControl": "off"
            },
            "complexity": {
                "noArguments": "error"
            },
            "style": {
                "useConst": "error",
                "noCommonJs": "error"
            },
            "suspicious": {
                "noExplicitAny": "error",
                "noVar": "error"
            },
            "correctness": {
                "useExhaustiveDependencies": "warn",
                "useHookAtTopLevel": "error"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double"
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
