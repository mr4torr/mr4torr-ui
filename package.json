{
    "name": "@mr4torr/ui",
    "version": "1.0.1",
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "files": [
        "dist",
        "src/styles"
    ],
    "scripts": {
        "build": "vite build && bunx tsc -p tsconfig.build.json",
        "lint": "eslint",
        "format": "prettier --write \"**/*.{ts,tsx}\"",
        "typecheck": "tsc --noEmit",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test": "vitest",
        "test:ui": "vitest --project=storybook",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "@base-ui/react": "^1.4.0",
        "@phosphor-icons/react": "^2.1.10",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwindcss": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "next-themes": {
            "optional": true
        }
    },
    "dependencies": {
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@base-ui/react": "^1.4.0",
        "@biomejs/biome": "2.4.12",
        "@chromatic-com/storybook": "^5.1.2",
        "@fontsource-variable/geist": "^5.2.8",
        "@phosphor-icons/react": "^2.1.10",
        "@storybook/addon-a11y": "^10.3.5",
        "@storybook/addon-docs": "^10.3.5",
        "@storybook/addon-onboarding": "^10.3.5",
        "@storybook/addon-themes": "^10.3.5",
        "@storybook/addon-vitest": "^10.3.5",
        "@storybook/react-vite": "^10.3.5",
        "@tailwindcss/vite": "^4.1.18",
        "@turbo/gen": "^2.8.1",
        "@types/node": "^25.1.0",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/browser-playwright": "^4.1.4",
        "@vitest/coverage-v8": "^4.1.4",
        "glob": "^11.0.0",
        "globals": "^17.2.0",
        "playwright": "^1.59.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "shadcn": "^4.3.0",
        "storybook": "^10.3.5",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    },
    "exports": {
        "./package.json": "./package.json",
        "./globals.css": "./dist/styles/globals.css",
        "./themes/lime.css": "./dist/styles/themes/lime.css",
        "./components/*": {
            "types": "./dist/components/*.d.ts",
            "import": "./dist/components/*.js"
        },
        "./lib/*": {
            "types": "./dist/lib/*.d.ts",
            "import": "./dist/lib/*.js"
        },
        "./hooks/*": {
            "types": "./dist/hooks/*.d.ts",
            "import": "./dist/hooks/*.js"
        }
    },
    "typesVersions": {
        "*": {
            "components/*": [
                "dist/components/*"
            ],
            "lib/*": [
                "dist/lib/*"
            ],
            "hooks/*": [
                "dist/hooks/*"
            ]
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mr4torr/mr4torr-ui.git"
    },
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
